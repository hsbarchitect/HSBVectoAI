# HSBVectoAI Backend — Environment Variables
# Copy this file to .env and fill in the values

# ─── App ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-secret-key-minimum-32-chars
DEBUG=false

# ─── Database ─────────────────────────────────────────────────────────────────
# Neon (recommended): postgresql+asyncpg://user:pass@ep-xxx.neon.tech/neondb?sslmode=require
# Local:             postgresql+asyncpg://postgres:postgres@localhost:5432/hsbvectoai
DATABASE_URL=postgresql+asyncpg://user:password@host/database

# ─── AI APIs ──────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
OPENAI_API_KEY=your-openai-api-key

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs (create in Stripe Dashboard)
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_STUDIO_MONTHLY=price_...
STRIPE_PRICE_STARTER_YEARLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_STUDIO_YEARLY=price_...

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Desktop app uses localhost, website uses your domain
ALLOWED_ORIGINS=http://localhost:3000,https://hsbvectoai.com
